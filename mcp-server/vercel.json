  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/mcp/:secret", "destination": "/api/mcp?pathsecret=:secret" },
    { "source": "/mcp", "destination": "/api/mcp" },
