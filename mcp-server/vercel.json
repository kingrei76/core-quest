{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/oauth?action=as-metadata" },
    { "source": "/.well-known/oauth-authorization-server/mcp", "destination": "/api/oauth?action=as-metadata" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/oauth?action=pr-metadata" },
    { "source": "/.well-known/oauth-protected-resource/mcp", "destination": "/api/oauth?action=pr-metadata" },
    { "source": "/register", "destination": "/api/oauth?action=register" },
    { "source": "/authorize", "destination": "/api/oauth?action=authorize" },
    { "source": "/token", "destination": "/api/oauth?action=token" },
    { "source": "/mcp/:secret", "destination": "/api/mcp?pathsecret=:secret" },
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/slack/interactivity", "destination": "/api/slack-interactivity" },
    { "source": "/health", "destination": "/api/health" }
  ]
}
